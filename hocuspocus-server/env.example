# Hocuspocus server config — kopier til .env og fyll inn.
# Filen skal IKKE checkes inn (.gitignore dekker .env).

# Port serveren lytter på lokalt. Bak Caddy proxy.
PORT=1234

# Supabase project URL — brukes til JWKS-endepunkt for JWT-verifisering.
# F.eks. https://ovefrsgtoxmfziqwdcdj.supabase.co
SUPABASE_URL=

# Prisma database connection — samme som main appen.
# Med pgbouncer=true&connection_limit=1 for pooled-tilkobling.
DATABASE_URL=

# Direct URL uten pooler (Prisma migration trenger denne, men runtime ikke).
DIRECT_URL=
