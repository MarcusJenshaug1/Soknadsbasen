{
  "name": "soknadsbasen-hocuspocus",
  "version": "0.1.0",
  "private": true,
  "description": "Yjs collab server for Søknadsbasen CV-editor. Deployes til Hetzner CX22 i Falkenstein.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "copy-schema": "mkdir -p prisma && cp ../prisma/schema.prisma prisma/schema.prisma",
    "prisma:generate": "npm run copy-schema && prisma generate",
    "predev": "npm run prisma:generate",
    "dev": "tsx watch src/server.ts",
    "prebuild": "npm run prisma:generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "npm run prisma:generate && tsc --noEmit"
  },
  "dependencies": {
    "@hocuspocus/extension-database": "^2.15.0",
    "@hocuspocus/extension-logger": "^2.15.0",
    "@hocuspocus/server": "^2.15.0",
    "@prisma/client": "^6.0.0",
    "jose": "^5.9.0",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
