# Offentlig hjemmeside-URL, brukes for canonical, OG, sitemap, robots, JSON-LD.
# Sett unicode-form (med ø), ikke punycode. Node normaliserer automatisk til xn--sknadsbasen-ggb.no.
NEXT_PUBLIC_SITE_URL=https://søknadsbasen.no

# Supabase — get from dashboard (Settings → API + Settings → Database)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres via Supabase poolers (IPv4-reachable)
DATABASE_URL=
DIRECT_URL=

# Optional — AI assistant
GEMINI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ONETIME=

# Stripe — Org licensing (create "Søknadsbasen Organisasjon" product in Stripe first)
# STRIPE_PRICE_ORG_SEAT = per-seat recurring price (NOK, monthly). Kilde-av-sannhet for pris i UI.
# Endringer her krever ikke kodeendring — UI henter beløp live via stripe.prices.retrieve.
STRIPE_PRICE_ORG_SEAT=
STRIPE_PRODUCT_INDIVIDUAL=
STRIPE_PRODUCT_ORG=

# Resend — transactional email (resend.com)
RESEND_API_KEY=
# Resend inbound webhook secret (optional but recommended)
RESEND_WEBHOOK_SECRET=

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Internal admin (your own email, grants app access + /admin routes)
ADMIN_EMAIL=marcus@jenshaug.no

# LinkedIn auto-poster (cron /api/cron/linkedin-jobs)
# Hentes fra LinkedIn Developer App #2 (Community Management). Se LINKEDIN_SETUP.md.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Refresh token kan være "dummy" så lenge LINKEDIN_DRY_RUN=1.
# Ekte token hentes via OAuth-flow etter Microsoft Vetting godkjenner Community Management API.
LINKEDIN_REFRESH_TOKEN=
# Organization URN for Søknadsbasen LinkedIn Page. Format: urn:li:organization:NNNNNNN
LINKEDIN_ORGANIZATION_URN=
# LinkedIn API-versjon. Bump kvartalsvis per LinkedIn-versjonsplan.
LINKEDIN_API_VERSION=202504
# Sett 1 for å logge payload uten å POST-e (smoke-test før Vetting-godkjenning).
LINKEDIN_DRY_RUN=1
