generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  user
  selger
  admin
}

/// App-level user profile. `id` matches the Supabase `auth.users.id` UUID.
/// Authentication (email, password, sessions) lives in Supabase Auth.
model User {
  id                   String             @id @db.Uuid
  email                String             @unique
  name                 String?
  /// Supabase Storage path for the avatar (inside the `avatars` bucket).
  avatarUrl            String?
  weeklyGoal           Int?
  /// DEPRECATED — kept one release for fallback, drop in next migration. Use `role` instead.
  isAdmin              Boolean            @default(false)
  /// Plattform-rolle. Selger = full Pro-tilgang uten subscription + tilgang til /selger.
  role                 UserRole           @default(user)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  resumes              Resume[]
  userData             UserData?
  companies            Company[]
  applications         JobApplication[]
  subscription         Subscription?
  sessions             JobSearchSession[]
  pushSubscriptions    PushSubscription[]
  notifications        Notification[]
  contacts             Contact[]
  shareLinks           ShareLink[]
  resumeShareLinks     ResumeShareLink[]
  orgMemberships       OrgMembership[]
  salesRepProfile      SalesRepProfile?
  attributedOrgs       Organization[]     @relation("SalesRepAttribution")
  commissionEntries    CommissionEntry[]  @relation("SalesRepCommission")
  commissionPayouts    CommissionPayout[] @relation("SalesRepPayout")
  payoutsCreated       CommissionPayout[] @relation("PayoutCreator")
  leads                Lead[]
  crmActivitiesCreated CrmActivity[]      @relation("CrmActivityCreator")

  @@index([role])
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String   @unique @db.Uuid
  stripeCustomerId     String
  stripeSubscriptionId String?  @unique
  type                 String // "monthly" | "one_time"
  status               String // "active" | "canceled" | "past_due" | "expired"
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

/// Stores all user data as JSON blobs — one row per user.
/// This is what the Zustand stores sync against when logged in.
model UserData {
  id              String   @id @default(uuid())
  userId          String   @unique @db.Uuid
  resumeData      String   @default("{}") // JSON blob of ResumeData
  coverLetterData String   @default("{}") // JSON blob of { letters, activeIndex }
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id        String   @id @default(uuid())
  title     String
  userId    String?  @db.Uuid
  guestId   String? // For gjestemodus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?           @relation(fields: [userId], references: [id])
  versions ResumeVersion[]
  sections Section[]
}

model Section {
  id        String  @id @default(uuid())
  resumeId  String
  title     String
  type      String // f.eks. "EXPERIENCE", "EDUCATION", "SKILLS"
  order     Int
  isVisible Boolean @default(true)

  resume Resume        @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  items  SectionItem[]
}

model SectionItem {
  id          String    @id @default(uuid())
  sectionId   String
  title       String?
  subtitle    String?
  startDate   DateTime?
  endDate     DateTime?
  description String?
  order       Int
  isVisible   Boolean   @default(true)

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model ResumeVersion {
  id         String   @id @default(uuid())
  resumeId   String
  versionNum Int      @default(1)
  content    Json // Snapshot av CV innhold på publiseringstidspunktet
  templateId String
  createdAt  DateTime @default(now())

  resume       Resume           @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  applications JobApplication[]
}

model Template {
  id         String   @id @default(uuid())
  name       String
  htmlLayout String? // Layout for export engine
  createdAt  DateTime @default(now())
}

// ─── Job search sessions ───────────────────────────────────

enum SessionStatus {
  ACTIVE
  CLOSED
}

enum SessionOutcome {
  GOT_JOB
  PAUSE
  OTHER
}

/// A bounded job-search period. One ACTIVE session per user at a time.
/// Applications belong to a session; profile/CV/subscription are global.
model JobSearchSession {
  id                   String          @id @default(uuid())
  userId               String          @db.Uuid
  name                 String
  status               SessionStatus   @default(ACTIVE)
  outcome              SessionOutcome?
  /// If outcome=GOT_JOB, the application that led to the offer.
  winningApplicationId String?
  startedAt            DateTime        @default(now())
  closedAt             DateTime?
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@index([userId, status])
}

// ─── Network contacts ────────────────────────────────────

/// A professional contact the user wants to keep track of.
model Contact {
  id              String    @id @default(uuid())
  userId          String    @db.Uuid
  name            String
  title           String?
  company         String?
  linkedinUrl     String?
  email           String?
  phone           String?
  photoUrl        String?
  notes           String?
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@index([userId])
}

// ─── Job application domain ────────────────────────────────

/// A company the user has applied to or is tracking.
model Company {
  id        String   @id @default(uuid())
  userId    String   @db.Uuid
  name      String
  website   String?
  industry  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications JobApplication[]
}

/// One job application per position.
model JobApplication {
  id               String    @id @default(uuid())
  userId           String    @db.Uuid
  companyId        String?
  /// Denormalised company name — always populated, even without a Company row.
  companyName      String
  /// Denormalised company website (hostname/URL). Used to derive the logo
  /// via favicon services and to link back to the company page.
  companyWebsite   String?
  title            String
  source           String? // "finn.no" | "linkedin" | "referral" | …
  jobUrl           String?
  status           String    @default("draft") // draft|applied|interview|offer|accepted|rejected|withdrawn
  statusNote       String?
  statusUpdatedAt  DateTime  @default(now())
  applicationDate  DateTime?
  deadlineAt       DateTime?
  interviewAt      DateTime?
  followUpAt       DateTime?
  offerSalary      String?
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  jobDescription   String?
  notes            String?
  /// Optional link to a ResumeVersion snapshot sent with this application.
  resumeSnapshotId String?
  archivedAt       DateTime?
  /// The job-search session this application belongs to. Null for pre-session data.
  sessionId        String?
  /// Optional network contact who referred or helped with this application.
  contactId        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         Company?              @relation(fields: [companyId], references: [id])
  session         JobSearchSession?     @relation(fields: [sessionId], references: [id])
  resumeSnapshot  ResumeVersion?        @relation(fields: [resumeSnapshotId], references: [id])
  tasks           Task[]
  attachments     Attachment[]
  activities      ApplicationActivity[]
  coverLetter     CoverLetter?
  interviewStages InterviewStage[]
  contact         Contact?              @relation(fields: [contactId], references: [id])
}

/// Checklist tasks tied to an application (follow-up, prep, documents …).
model Task {
  id            String    @id @default(uuid())
  applicationId String
  title         String
  description   String? // Optional detailed notes
  dueAt         DateTime?
  completedAt   DateTime?
  /// "followup" | "document" | "research" | "interview" | "other"
  type          String?
  /// "low" | "medium" | "high" | "urgent"
  priority      String    @default("medium")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

/// File attachments for an application (stored on disk / object storage).
model Attachment {
  id            String   @id @default(uuid())
  applicationId String
  filename      String
  mimeType      String
  sizeBytes     Int
  /// Relative path on disk, e.g. "uploads/<userId>/<uuid>.<ext>"
  storageKey    String
  createdAt     DateTime @default(now())

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

/// Immutable event log for an application (status changes, meetings, notes …).
model ApplicationActivity {
  id            String   @id @default(uuid())
  applicationId String
  /// "status" | "deadline" | "interview" | "followup" | "offer" | "note" | "communication"
  type          String
  /// For type="communication": "outbound" (du sendte) | "inbound" (du mottok). Null for other types.
  direction     String?
  /// For type="communication": "email" | "sms" | "call" | "meeting" | "linkedin" | "other".
  channel       String?
  note          String?
  occurredAt    DateTime @default(now())

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

/// Cover letter / søknadsbrev for an application.
model CoverLetter {
  id             String   @id @default(uuid())
  applicationId  String   @unique
  /// Sender info
  senderName     String?
  senderEmail    String?
  senderPhone    String?
  senderLocation String?
  /// Recipient
  recipientName  String?
  recipientTitle String?
  companyAddress String?
  /// Letter content
  date           String?
  subject        String?
  greeting       String?
  body           String? // HTML from Lexical
  closing        String?
  /// Design
  fontFamily     String   @default("inter")
  accentColor    String   @default("#4f46e5")
  fontSize       String   @default("medium")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

// ─── Interview stages ────────────────────────────────────

/// One interview round within a job application.
model InterviewStage {
  id            String    @id @default(uuid())
  applicationId String
  round         Int
  /// "phone" | "technical" | "hr" | "final" | "other"
  type          String    @default("other")
  scheduledAt   DateTime?
  /// "pending" | "passed" | "failed" | "cancelled"
  outcome       String    @default("pending")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

// ─── Share links ─────────────────────────────────────────

/// Read-only token for sharing a pipeline view with a coach or mentor.
model ShareLink {
  id        String    @id @default(uuid())
  userId    String    @db.Uuid
  token     String    @unique @default(uuid())
  label     String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

/// Public-facing CV share link. Live binding to UserData._resumeDataMap[resumeId].
/// Recruiter opens /cv/delt/<token> without authentication.
model ResumeShareLink {
  id           String    @id @default(uuid())
  userId       String    @db.Uuid
  /// Key into UserData.resumeData JSON (_resumeDataMap entry). Not a FK.
  resumeId     String
  token        String    @unique
  label        String?
  expiresAt    DateTime?
  revokedAt    DateTime?
  viewCount    Int       @default(0)
  lastViewedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─── Web Push ────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @db.Uuid
  endpoint  String
  auth      String
  p256dh    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
}

model Notification {
  id     String    @id @default(uuid())
  userId String    @db.Uuid
  title  String
  body   String
  url    String?
  readAt DateTime?
  sentAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, sentAt])
}

// ─── Organisation licensing ───────────────────────────────

model Organization {
  id                   String   @id @default(uuid())
  /// URL-safe identifier used in all routes: /org/[slug]
  slug                 String   @unique
  /// Public display name shown in whitelabeled header
  displayName          String
  /// Internal/legal name
  name                 String
  logoUrl              String?
  /// Hex colour for whitelabel header, e.g. "#D5592E"
  brandColor           String?
  /// Org's own Stripe customer (NOT the admin's personal customer)
  stripeCustomerId     String?
  /// Per-seat recurring subscription
  stripeSubscriptionId String?  @unique
  /// "active" | "trialing" | "past_due" | "canceled" | "incomplete"
  status               String   @default("incomplete")
  /// Antall forhåndskjøpte lisenser (= Stripe sub item quantity)
  seatLimit            Int      @default(1)
  /// "card" | "invoice" — hvordan kunden betaler
  billingMethod        String   @default("card")
  /// Organisasjonsnummer (9 siffer). Påkrevd for invoice-billing.
  orgNumber            String?
  /// Faktura-epost (brukes av Stripe Invoicing)
  invoiceEmail         String?
  /// FK til User.id der role=selger. Null = ingen attribusjon.
  salesRepId           String?  @db.Uuid
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  memberships       OrgMembership[]
  invites           OrgInvite[]
  salesRep          User?             @relation("SalesRepAttribution", fields: [salesRepId], references: [id], onDelete: SetNull)
  lead              Lead?
  commissionEntries CommissionEntry[]
  crmContacts       CrmContact[]

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([salesRepId])
}

model OrgMembership {
  id                String   @id @default(uuid())
  orgId             String
  userId            String   @db.Uuid
  /// "admin" | "member"
  role              String   @default("member")
  /// "invited" | "active" | "suspended"
  status            String   @default("active")
  /// Whether the org admin can see this member's CVs and applications
  sharesDataWithOrg Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@index([orgId, status])
}

/// Invitation for a user who may not have registered yet.
model OrgInvite {
  id        String   @id @default(uuid())
  orgId     String
  email     String
  /// Secure random token sent in the invite link
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([token])
}

/// Org access inquiries submitted from the register page
model OrgInquiry {
  id           String   @id @default(uuid())
  orgName      String
  contactName  String
  contactEmail String
  message      String?
  /// "pending" | "contacted" | "dismissed"
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  lead Lead?

  @@index([status, createdAt])
}

/// Custom folders for the admin inbox
model EmailFolder {
  id        String   @id @default(uuid())
  name      String
  parentId  String?
  createdAt DateTime @default(now())

  parent   EmailFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children EmailFolder[] @relation("FolderTree")

  inboundEmails InboundEmail[]
  sentEmails    SentEmail[]

  @@index([parentId])
}

/// Inbound emails received via Resend webhook
model InboundEmail {
  id          String    @id @default(uuid())
  fromAddress String
  fromName    String?
  toAddress   String
  subject     String
  textBody    String?
  htmlBody    String?
  messageId   String?
  folderId    String?
  archived    Boolean   @default(false)
  deletedAt   DateTime?
  receivedAt  DateTime  @default(now())

  folder EmailFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([receivedAt])
  @@index([folderId])
  @@index([archived])
  @@index([deletedAt])
}

/// Emails sent from the admin inbox
model SentEmail {
  id        String    @id @default(uuid())
  toAddress String
  subject   String
  textBody  String?
  htmlBody  String?
  inReplyTo String?
  folderId  String?
  archived  Boolean   @default(false)
  deletedAt DateTime?
  sentAt    DateTime  @default(now())

  folder EmailFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([sentAt])
  @@index([folderId])
  @@index([archived])
  @@index([deletedAt])
}

// ─── Selger / CRM / Provisjon ─────────────────────────────

/// Per-bruker data kun for users med role=selger.
model SalesRepProfile {
  id                String    @id @default(uuid())
  userId            String    @unique @db.Uuid
  /// Basispoint. 1000 = 10.00%. Per-selger overstyring.
  commissionRateBp  Int       @default(1000)
  /// Månedlig MRR-mål i øre. 5000000 = 50 000 NOK.
  monthlyQuotaCents Int       @default(0)
  /// "invited" | "active" | "suspended"
  status            String    @default("invited")
  inviteToken       String?   @unique
  inviteExpiresAt   DateTime?
  /// Round-robin pointer.
  lastAssignedAt    DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, lastAssignedAt])
}

/// CRM lead — én modell for hele pipeline. "Vunnet"/"Tapt" er bare stage-verdier.
model Lead {
  id                  String    @id @default(uuid())
  salesRepId          String    @db.Uuid
  /// "Ny" | "Kontaktet" | "Demo booket" | "Tilbud sendt" | "Forhandling" | "Vunnet" | "Tapt"
  stage               String    @default("Ny")
  probability         Int       @default(10)
  /// "manual" | "inquiry" | "web_form" | "referral"
  source              String    @default("manual")
  estimatedValueCents Int       @default(0)
  expectedSeats       Int       @default(1)
  title               String
  companyName         String
  companyWebsite      String?
  notes               String?
  orgInquiryId        String?   @unique
  orgId               String?   @unique
  lostReason          String?
  closedAt            DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  salesRep   User              @relation(fields: [salesRepId], references: [id], onDelete: Cascade)
  org        Organization?     @relation(fields: [orgId], references: [id], onDelete: SetNull)
  orgInquiry OrgInquiry?       @relation(fields: [orgInquiryId], references: [id], onDelete: SetNull)
  contacts   LeadContactLink[]
  activities CrmActivity[]

  @@index([salesRepId, stage])
  @@index([stage, closedAt])
  @@index([source, createdAt])
}

/// CRM-kontakt — distinkt fra eksisterende `Contact` (network-modell for end-users).
model CrmContact {
  id          String   @id @default(uuid())
  /// Optional org-binding — kobles direkte når Lead konverteres.
  orgId       String?
  name        String
  title       String?
  email       String?
  phone       String?
  linkedinUrl String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org   Organization?     @relation(fields: [orgId], references: [id], onDelete: SetNull)
  leads LeadContactLink[]

  @@index([orgId])
  @@index([email])
}

/// M2M: Lead ↔ CrmContact med rolle.
model LeadContactLink {
  id        String   @id @default(uuid())
  leadId    String
  contactId String
  /// "Beslutningstaker" | "Bruker" | "Champion"
  role      String   @default("Bruker")
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  lead    Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contact CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([leadId, contactId])
  @@index([contactId])
}

/// Aktivitet på en lead: notat, oppgave, telefon, møte, e-post (manuelt loggført).
model CrmActivity {
  id          String    @id @default(uuid())
  leadId      String
  /// "note" | "task" | "call" | "meeting" | "email"
  type        String
  title       String?
  content     String?
  dueAt       DateTime?
  completedAt DateTime?
  durationMin Int?
  createdById String    @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User @relation("CrmActivityCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([createdById, dueAt])
}

/// Provisjon-entry per Stripe-faktura. 90-dagers clawback håndteres via holdUntil + status.
model CommissionEntry {
  id                 String   @id @default(uuid())
  salesRepId         String   @db.Uuid
  orgId              String
  /// Stripe invoice id — unique = idempotente webhooks.
  stripeInvoiceId    String   @unique
  invoiceAmountCents Int
  /// Provisjon-andel = invoiceAmountCents × commissionRateBp / 10_000.
  amountCents        Int
  /// paidAt + 90 dager. Cron flagger `eligible` når både holdUntil passert OG ≥3 paid invoices for orgen.
  holdUntil          DateTime
  /// "pending" | "eligible" | "paid" | "clawback" | "voided"
  status             String   @default("pending")
  paidAt             DateTime
  payoutId           String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  salesRep User              @relation("SalesRepCommission", fields: [salesRepId], references: [id], onDelete: Cascade)
  org      Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  payout   CommissionPayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([salesRepId, status])
  @@index([orgId, paidAt])
  @@index([status, holdUntil])
}

/// Offentlig jobbaggregator. Stillinger hentes fra NAV/Arbeidsplassen
/// public feed via /api/cron/jobs-sync. URL-er bruker slug, ikke UUID.
model Job {
  id            String    @id @default(cuid())
  externalId    String    @unique
  source        String    @default("arbeidsplassen")

  title         String
  slug          String    @unique
  employerName  String
  employerSlug  String

  description   String
  location      String?
  region        String?
  category      String?
  occupation    String?
  employmentType String?

  applyUrl      String?

  publishedAt   DateTime
  expiresAt     DateTime?

  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([slug])
  @@index([employerSlug])
  @@index([region, category])
  @@index([isActive, publishedAt])
  @@index([externalId])
}

/// En utbetaling fra admin til selger. Samler N entries.
model CommissionPayout {
  id          String   @id @default(uuid())
  salesRepId  String   @db.Uuid
  totalCents  Int
  paidAt      DateTime
  paymentRef  String?
  notes       String?
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())

  salesRep  User              @relation("SalesRepPayout", fields: [salesRepId], references: [id], onDelete: Cascade)
  createdBy User              @relation("PayoutCreator", fields: [createdById], references: [id], onDelete: Cascade)
  entries   CommissionEntry[]

  @@index([salesRepId, paidAt])
}
